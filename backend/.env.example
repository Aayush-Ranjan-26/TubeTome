# Server port
PORT=3001

# YouTube Data API key (from Google Cloud Console)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Supabase (for server-side JWT verification)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# CORS — by default, any HTTPS origin is allowed (safe because all routes
# require a valid Supabase JWT, which attackers cannot forge).
# Use ALLOWED_ORIGINS to additionally permit specific non-HTTPS origins:
# ALLOWED_ORIGINS=https://yourdomain.com,https://another.com
#
# Use ALLOWED_ORIGIN_PATTERNS for regex patterns (e.g. Vercel preview branches):
# ALLOWED_ORIGIN_PATTERNS=^https://myapp-[a-z0-9-]+\.vercel\.app$

# Environment — set to "production" for deployments
# NODE_ENV=production
